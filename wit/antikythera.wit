package antikythera:mcp-framework@1.0.0;

/// LlmRequest
record llm-request {
  provider: option<string>,
  model: option<string>,
  session-id: option<string>,
  messages-json: string,
  force-json: bool,
  temperature: option<float32>,
  max-tokens: option<u32>,
  schema-name: option<string>,
  metadata-json: option<string>,
}

/// LlmResponse
record llm-response {
  content: string,
  model: option<string>,
  session-id: option<string>,
  message-json: option<string>,
  tokens-used: option<u32>,
  finish-reason: option<string>,
  raw-response-json: option<string>,
}

/// ToolCallEvent
record tool-call-event {
  tool-name: string,
  arguments-json: string,
  session-id: option<string>,
  step-id: u32,
}

/// ToolExecutionResult
record tool-execution-result {
  tool-name: string,
  success: bool,
  output-json: string,
  error-message: option<string>,
  step-id: u32,
}

/// LogEvent
record log-event {
  level: string,
  message: string,
  timestamp: option<string>,
}

/// DelegatingAgent<H: HostImports>
record delegating-agent<-h: -host-imports> {
  host: h,
  session-id: option<string>,
  step-counter: u32,
  max-steps: u32,
}

/// HostImports
interface host-imports {
  log-message(event: log-event);
}

/// Combined world exporting both interfaces
world antikythera-mcp {
  export prompt-manager;
  export mcp-client;
  export ffi-server;
}
