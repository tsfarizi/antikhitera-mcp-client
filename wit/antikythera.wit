/// Antikythera MCP Framework - WASM Component Interface
///
/// WASM hanya menerima response LLM dari host, TIDAK memanggil API langsung.
/// Host bertanggung jawab untuk:
/// - LLM API calls (OpenAI, Anthropic, Gemini, Ollama, dll)
/// - API key management
/// - Rate limiting & retry logic
/// - MCP tool execution

// ============================================================================
// Host Imports (disediakan oleh host runtime)
// ============================================================================

/// LLM request dari WASM ke host
record llm-request {
    /// Prompt messages (JSON encoded)
    messages-json: string,
    /// System prompt
    system-prompt: string,
    /// Temperature (0.0 - 2.0)
    temperature: option<f32>,
    /// Max tokens
    max-tokens: option<u32>,
    /// Expected response schema name (optional)
    schema-name: option<string>,
}

/// LLM response dari host ke WASM
record llm-response {
    /// Response content
    content: string,
    /// Model yang digunakan
    model: string,
    /// Tokens used
    tokens-used: option<u32>,
    /// Finish reason
    finish-reason: option<string>,
}

/// Tool call event dari WASM ke host
record tool-call-event {
    /// Tool name
    tool-name: string,
    /// Tool arguments (JSON encoded)
    arguments-json: string,
    /// Session ID for tracking
    session-id: option<string>,
    /// Step ID for ordering
    step-id: u32,
}

/// Tool execution result dari host ke WASM
record tool-execution-result {
    /// Tool name
    tool-name: string,
    /// Success status
    success: bool,
    /// Output (JSON encoded)
    output-json: string,
    /// Error message if failed
    error-message: option<string>,
    /// Step ID
    step-id: u32,
}

/// Log event dari WASM ke host
record log-event {
    /// Log level (debug, info, warn, error)
    level: string,
    /// Message
    message: string,
    /// Timestamp (ISO 8601)
    timestamp: option<string>,
}

/// State persistence
interface host-imports {
    /// Call LLM API (host responsibility)
    call-llm(request: llm-request) -> result<llm-response, string>;

    /// Execute tool call via MCP (host responsibility)
    emit-tool-call(event: tool-call-event) -> result<tool-execution-result, string>;

    /// Log message to host
    log-message(event: log-event);

    /// Save agent state (host decides storage backend)
    save-state(session-id: string, state-json: string) -> result<_, string>;

    /// Load agent state (host decides storage backend)
    load-state(session-id: string) -> result<option<string>, string>;
}

// ============================================================================
// WASM Exports (disediakan oleh WASM component)
// ============================================================================

/// Agent action result dari WASM
variant agent-action {
    /// Call a tool
    call-tool(tool-call-event),
    /// Final response to user
    final-response(string),
    /// Need retry with error feedback
    retry-with-error(string),
}

/// Agent processing result
record agent-outcome {
    /// Action to take
    action: agent-action,
    /// Current step number
    step: u32,
    /// Session ID
    session-id: string,
}

/// Agent configuration (minimal, tanpa provider info)
record agent-config {
    /// Maximum steps
    max-steps: u32,
    /// Verbose logging
    verbose: bool,
    /// Auto-execute tools
    auto-execute-tools: bool,
    /// Session timeout (seconds)
    session-timeout-secs: u32,
}

/// JSON Schema for validation (WASM enforce consistency)
record json-schema-def {
    /// Schema name
    name: string,
    /// Schema definition (JSON encoded)
    schema-json: string,
    /// Whether to enforce
    enforced: bool,
}

/// Agent session state
record agent-state {
    /// Session ID
    session-id: string,
    /// Current step
    current-step: u32,
    /// Message history (JSON encoded)
    message-history: string,
    /// Tool call results (JSON encoded)
    tool-results: string,
    /// Metadata (JSON encoded)
    metadata: string,
}

/// Agent interface
interface agent-runner {
    /// Initialize agent with config
    init(config-json: string) -> result<string, string>;

    /// Process LLM response and determine next action
    process-llm-response(
        session-id: string,
        llm-response-json: string,
    ) -> result<string, string>;

    /// Process tool execution result
    process-tool-result(
        session-id: string,
        tool-result-json: string,
    ) -> result<string, string>;

    /// Get current agent state
    get-state(session-id: string) -> result<string, string>;

    /// Reset agent session
    reset-session(session-id: string) -> result<bool, string>;
}

/// JSON Schema validation
interface json-schema-validator {
    /// Register a schema
    register-schema(schema-json: string) -> result<string, string>;

    /// Validate JSON against registered schema
    validate-json(schema-name: string, json-string: string) -> result<string, string>;

    /// Generate example JSON from schema
    generate-example(schema-name: string) -> result<string, string>;

    /// Get schema prompt instruction
    get-schema-prompt(schema-name: string) -> result<string, string>;
}

/// Prompt template management
interface prompt-manager {
    /// Get prompt template by name
    get-prompt(name: string) -> result<string, string>;

    /// Set prompt template
    set-prompt(name: string, value: string) -> result<bool, string>;

    /// Render prompt with variables
    render-prompt(template: string, variables-json: string) -> result<string, string>;
}

/// Session management
interface session-manager {
    /// Create a new session
    create-session(user-id: string, model: string) -> result<string, string>;

    /// Get session by ID
    get-session(session-id: string) -> result<string, string>;

    /// List all sessions
    list-sessions() -> result<string, string>;

    /// Add message to session
    add-message(session-id: string, role: string, content: string) -> result<string, string>;

    /// Get chat history
    get-history(session-id: string) -> result<string, string>;

    /// Export session to hex-encoded Postcard
    export-session(session-id: string) -> result<string, string>;

    /// Import session from hex-encoded Postcard
    import-session(export-data: string) -> result<string, string>;

    /// Delete session
    delete-session(session-id: string) -> result<string, string>;

    /// Clear session messages
    clear-session(session-id: string) -> result<string, string>;

    /// Export all sessions as batch
    batch-export() -> result<string, string>;

    /// Import batch of sessions
    batch-import(export-data: string) -> result<string, string>;

    /// Get logs for a session
    get-session-logs(session-id: string) -> result<string, string>;

    /// Export session logs to hex-encoded Postcard
    export-session-logs(session-id: string) -> result<string, string>;

    /// Import session logs from hex-encoded Postcard
    import-session-logs(export-data: string) -> result<string, string>;

    /// Export all session logs as batch
    batch-export-logs() -> result<string, string>;

    /// Import batch of session logs
    batch-import-logs(export-data: string) -> result<string, string>;
}

// ============================================================================
// World definition
// ============================================================================

/// Multi-agent orchestration runner (FFI-facing).
///
/// All parameters and return values are JSON strings so the interface stays
/// WASM-component-friendly.  The host language specifies execution preferences
/// via the `orchestrator-config` JSON rather than managing threads directly.
///
/// # Execution mode string format
///
/// - `"auto"`         — default; tokio concurrency, efficient on any thread count
/// - `"sequential"`   — tasks run one after another in order
/// - `"concurrent"`   — concurrent async on the calling thread (no spawning)
/// - `"parallel:N"`   — spawn N concurrent tasks (e.g. `"parallel:4"`)
interface multi-agent-runner {
    /// Initialise (or re-initialise) the orchestrator.
    ///
    /// `config-json` must deserialise to:
    /// ```json
    /// { "execution_mode": "auto" }
    /// ```
    /// Returns `true` on success.
    init-orchestrator(config-json: string) -> result<bool, string>;

    /// Register an agent profile.
    ///
    /// `profile-json` must deserialise to:
    /// ```json
    /// {
    ///   "id": "reviewer",
    ///   "name": "Code Reviewer",
    ///   "role": "code-review",
    ///   "system_prompt": "You are an expert code reviewer.",
    ///   "max_steps": 10
    /// }
    /// ```
    register-agent(profile-json: string) -> result<bool, string>;

    /// Dispatch a single task and return the JSON-encoded `TaskResult`.
    ///
    /// `task-json` must deserialise to:
    /// ```json
    /// {
    ///   "task_id": "uuid",
    ///   "agent_id": "reviewer",
    ///   "input": "Review my PR",
    ///   "session_id": null,
    ///   "max_steps": null
    /// }
    /// ```
    dispatch-task(task-json: string) -> result<string, string>;

    /// Dispatch multiple tasks.
    ///
    /// `tasks-json` is a JSON array of task objects (same schema as
    /// `dispatch-task`).  Returns a JSON array of `TaskResult` objects.
    dispatch-tasks(tasks-json: string) -> result<string, string>;

    /// Execute tasks as a sequential pipeline.
    ///
    /// Each task's output is injected as context into the next task's input.
    /// Returns a JSON-encoded `PipelineResult`.
    pipeline-tasks(tasks-json: string) -> result<string, string>;

    /// Return a JSON object with orchestrator status:
    /// `{ "agent_count": N, "execution_mode": "auto" }`
    get-status() -> result<string, string>;
}

world antikythera-agent {
    /// Import dari host (I/O operations - host responsibility)
    import host-imports;

    /// Export ke host (agent logic - WASM responsibility)
    export agent-runner;
    export json-schema-validator;
    export prompt-manager;
    export session-manager;
    export multi-agent-runner;
}
